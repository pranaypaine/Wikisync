# Wiki Server Configuration
# Copy this to .env and modify as needed

# SQLite database file path
DATABASE_URL=sqlite:wiki.db

# JWT secret — change this to a long random string in production!
JWT_SECRET=change-me-to-a-long-random-secret

# JWT token expiry in seconds (default: 7 days)
JWT_EXPIRY_SECS=604800

# Server port (default: 3000)
PORT=3000

# Log level: error | warn | info | debug | trace
RUST_LOG=wiki_server=info,tower_http=info
